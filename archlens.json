{
    "$schema": "https://raw.githubusercontent.com/archlens/ArchLens/master/src/python/config.schema.json",
    "name": "ArchLens",
    "rootFolder": "src/python/src",
    "github": {
        "url": "https://github.com/archlens/ArchLens",
        "branch": "master"
    },
    "snapshotDir": ".archlens",
    "snapshotFile": "snapshot",
    "saveLocation": "/diagrams/",
    "exclusions": [
        "obj/",
        "bin/",
        ".vs/",
        ".git/",
        ".idea/",
        ".archlens"
    ],
    "fileExtensions": [
        ".py"
    ],
    "views": {
        "completeView": {
            "packages": [
                {
                    "path": "*",
                    "depth": 3
                }
            ],
            "ignorePackages": []
        }
    }
}